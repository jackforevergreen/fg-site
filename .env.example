# YouTube Data API Configuration
# Get your API key from: https://console.developers.google.com/

# Required: YouTube Data API v3 key
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Override the default channel ID
# VITE_YOUTUBE_CHANNEL_ID=UC_your_channel_id_here

# Stripe Configuration
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# Use test key (pk_test_...) for development, live key (pk_live_...) for production

# Required: Stripe publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Firebase Configuration (optional overrides)
# These values default to the fg-react-app project if not specified
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
# VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id